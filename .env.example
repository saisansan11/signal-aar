# Signal AAR — Firebase config
# Copy this file to .env and fill in the values from Firebase Console
# Project Console: https://console.firebase.google.com/project/signal-aar-system/overview

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=signal-aar-system.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=signal-aar-system
VITE_FIREBASE_STORAGE_BUCKET=signal-aar-system.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
